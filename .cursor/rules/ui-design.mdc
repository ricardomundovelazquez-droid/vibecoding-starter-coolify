## Patrones de código

### Componente con shadcn
```tsx
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { Badge } from '@/components/ui/badge'
import { cn } from '@/lib/utils'

interface Props {
  title: string
  status: 'active' | 'inactive'
  className?: string
}

export function ItemCard({ title, status, className }: Props) {
  return (
    <Card className={cn('hover:shadow-md transition-shadow', className)}>
      <CardHeader className="flex flex-row items-center justify-between pb-2">
        <CardTitle className="text-sm font-medium">{title}</CardTitle>
        <Badge variant={status === 'active' ? 'default' : 'secondary'}>
          {status === 'active' ? 'Activo' : 'Inactivo'}
        </Badge>
      </CardHeader>
    </Card>
  )
}
```

### Hero con Magic UI
```tsx
import { BlurFade } from '@/components/magicui/blur-fade'
import { AnimatedGradientText } from '@/components/magicui/animated-gradient-text'
import { ShimmerButton } from '@/components/magicui/shimmer-button'
import { DotPattern } from '@/components/magicui/dot-pattern'

export function HeroSection() {
  return (
    <section className="relative flex flex-col items-center justify-center min-h-screen text-center px-4">
      <DotPattern className="absolute inset-0 opacity-40" />
      <div className="relative z-10 space-y-6 max-w-3xl">
        <BlurFade delay={0.1}>
          <AnimatedGradientText>Novedad</AnimatedGradientText>
        </BlurFade>
        <BlurFade delay={0.2}>
          <h1 className="text-4xl md:text-6xl font-bold tracking-tight">
            Tu headline aquí
          </h1>
        </BlurFade>
        <BlurFade delay={0.3}>
          <ShimmerButton>Empezar gratis</ShimmerButton>
        </BlurFade>
      </div>
    </section>
  )
}
```

## Checklist por componente
- [ ] Si existe docs/DESIGN.md → tokens aplicados en globals.css
- [ ] Sin colores, spacing o font-size hardcodeados fuera del sistema
- [ ] Acepta `className` para extensibilidad
- [ ] Dark mode funciona (`text-foreground`, `bg-background`, etc.)
- [ ] Estados: loading (Skeleton), error, empty, success
- [ ] `focus-visible:ring-2` en elementos interactivos
- [ ] Mobile-first: 375px base, expande con `sm:` `md:` `lg:`
