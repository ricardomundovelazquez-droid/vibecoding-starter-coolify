# Base de datos — obtener de Coolify o Docker local
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Auth.js — generar con: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://tu-dominio.com

# OAuth Providers (agregar los que uses)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# MinIO — obtener de Coolify
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
